#Import the data set 
insurance_data = read.csv("c:\\Insurance_data.csv",header = TRUE) 
head(insurance_data) 
 
#clean the data set 
data <- insurance_data[complete.cases(insurance_data) & !apply(insurance_data 
== "", 1, any), ] 
nrow(data) 
summary(data) 
 
#Install "survey" package 
install.packages("survey") 
library(survey) 
 
###-----------Simple Random Sample------------###  
#Calculate Sample size  
install.packages("sampler") 
library(sampler) 
n<- rsampcalc(nrow(data), e=3, ci=95) 
n 
 
#draw the sample1 
set.seed(12345) 
SRS_Sample1 = rsamp(df = data, n=n, rep = FALSE) 
SRS_Sample1 

   
 
#--------Sample1--------# 
#obtain weights 
SRS_Sample1$weight <- nrow(data) / n 
 
#defining the survey design object 
SRS_Sample1_design= svydesign(id=~1, weights=SRS_Sample1$weight , data= 
SRS_Sample1) 
summary(SRS_Sample1_design) 
 
#Estimating the mean values 
svymean(~age,SRS_Sample1_design) 
svymean(~bmi,SRS_Sample1_design) 
svymean(~bloodpressure,SRS_Sample1_design) 
svymean(~children,SRS_Sample1_design) 
svymean(~claim,SRS_Sample1_design) 
 
#Estimating the proportions  
svymean(~gender,SRS_Sample1_design) 
svymean(~diabetic,SRS_Sample1_design) 
svymean(~smoker,SRS_Sample1_design) 
svymean(~region,SRS_Sample1_design) 
 
#Estimating the totals 
svytotal(~gender,SRS_Sample1_design) 
svytotal(~diabetic,SRS_Sample1_design) 
svytotal(~smoker,SRS_Sample1_design) 
svytotal(~region,SRS_Sample1_design) 

 
 
#regression estimations 
plot(SRS_Sample1$claim,SRS_Sample1$age) 
plot(SRS_Sample1$claim,SRS_Sample1$bmi) 
plot(SRS_Sample1$claim,SRS_Sample1$bloodpressure) 
plot(SRS_Sample1$claim,SRS_Sample1$children) 
SLR1 = lm(claim ~ bloodpressure, data = SRS_Sample1) 
summary(SLR1) 
mean_Claim = coef(SLR1)[1] + coef(SLR1)[2]*mean(data$bloodpressure) 
mean_Claim 
 
 
